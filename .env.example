# =============================================================================
# K Real Estate — variables de entorno (template)
# =============================================================================
# Copiar este archivo como .env.local y rellenar con las claves reales.
# .env.local NUNCA se commitea (ya está en .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — base de datos, auth, storage, realtime
# -----------------------------------------------------------------------------
# Cuenta del cliente. Crear proyecto en supabase.com → región sa-east-1 (São Paulo).
# Settings → API:
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Service role key — operaciones admin del lado servidor (RLS bypass).
# NUNCA exponer al cliente. NUNCA prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# -----------------------------------------------------------------------------
# Anthropic — agentes IA (Claude Sonnet/Haiku)
# -----------------------------------------------------------------------------
# Cuenta del cliente. Generar key en console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-tu-clave

# Modelo por defecto para los agentes (override por agente desde DB).
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Kommo — CRM operativo del cliente (WhatsApp Business + leads + pipelines)
# -----------------------------------------------------------------------------
# El cliente ya tiene cuenta. Pedir long-lived API token + subdomain.
# Docs: developers.kommo.com
KOMMO_SUBDOMAIN=krealestate
KOMMO_LONG_LIVED_TOKEN=eyJ0eXAi...

# Webhook secret — validar que los webhooks entrantes vengan de Kommo.
KOMMO_WEBHOOK_SECRET=generar-uno-largo-aleatorio

# -----------------------------------------------------------------------------
# Google APIs — Calendar (visitas) + Maps (traslados)
# -----------------------------------------------------------------------------
# Service account JSON con acceso a info@eko-realestate.com (Calendar compartido).
# Pegar el JSON completo en una sola línea o usar GOOGLE_APPLICATION_CREDENTIALS_PATH.
GOOGLE_SERVICE_ACCOUNT_JSON=

# API key de Google Maps (Distance Matrix API habilitada).
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# OpenWeather — clima previsto para coordinación de visitas
# -----------------------------------------------------------------------------
# Free tier alcanza para el caché diario. openweathermap.org/api
OPENWEATHER_API_KEY=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
